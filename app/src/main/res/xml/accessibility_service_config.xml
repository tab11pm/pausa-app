<?xml version="1.0" encoding="utf-8"?>
<!--
  Watches window-state changes across all apps. We don't hard-code package
  names here because the user picks which apps to intercept at runtime;
  the service reads that list from DataStore and ignores everything else.
  flagRetrieveInteractiveWindows is NOT requested — we only need the
  foreground package name, not screen content, which keeps the permission
  footprint minimal.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:notificationTimeout="100"
    android:canRetrieveWindowContent="false"
    android:description="@string/accessibility_service_description" />
