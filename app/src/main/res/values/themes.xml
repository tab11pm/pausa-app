<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme for the host Activity before Compose takes over.
         Compose drives the real visuals; this just sets a dark background
         so there is no white flash on launch. -->
    <style name="Theme.MindfulPause" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
